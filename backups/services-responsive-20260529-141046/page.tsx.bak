        <div className="mt-8 rounded-3xl border border-slate-200 bg-white p-5 shadow-sm sm:mt-12 sm:p-8">
          <div className="max-w-3xl">
            <p className="text-xs font-black uppercase tracking-[0.22em] text-slate-500">
