                <h3 className="text-sm font-black text-slate-950">
                  {isTr ? item.titleTr : item.title}
                </h3>
                <p className="mt-2 text-xs leading-5 text-slate-600 sm:text-sm sm:leading-6">
                  {isTr ? item.descriptionTr : item.description}
                </p>
              </div>
            ))}
          </div>
        </div>

        <div className="mt-8 rounded-3xl border border-slate-200 bg-slate-950 p-5 text-white shadow-sm sm:mt-12 sm:p-8">
          <div className="grid gap-6 lg:grid-cols-[1.4fr_0.6fr] lg:items-center">
            <div>
              <p className="text-xs font-black uppercase tracking-[0.22em] text-slate-400">
                {isTr ? "Fiyatlandırma" : "Pricing"}
              </p>
              <h2 className="mt-3 text-2xl font-black sm:text-3xl">
                {isTr ? "Fiyat, projenin kapsamına göre netleştirilir" : "Pricing is clarified according to project scope"}
