                {isTr ? "İhtiyacımı Yazıp Fiyat Almak İstiyorum" : "I Want to Get a Quote"}
              </Button>
              <Button
                href="/projects"
                variant="secondary"
                className="h-11 min-h-11 justify-center px-5 text-sm"
              >
                {isTr ? "Canlı Örnekleri İncele" : "View Live Demos"}
              </Button>
            </div>
          </div>
        </div>
      </Container>
