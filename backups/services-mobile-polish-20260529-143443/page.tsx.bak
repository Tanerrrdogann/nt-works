                  {isTr ? item.titleTr : item.title}
                </h3>

                <p className="mt-2 text-[11px] leading-5 text-slate-600 sm:text-xs sm:leading-5 lg:text-sm lg:leading-6">
                  {isTr ? item.descriptionTr : item.description}
                </p>
              </div>
            ))}
          </div>
        </div>

        <div className="mt-8 rounded-2xl border border-slate-200 bg-slate-950 p-4 text-white shadow-sm sm:mt-10 sm:rounded-3xl sm:p-6 lg:p-8">
          <div className="grid gap-5 lg:grid-cols-[1.4fr_0.6fr] lg:items-center lg:gap-8">
            <div>
              <p className="text-[11px] font-black uppercase tracking-[0.2em] text-slate-400 sm:text-xs">
