              >
                <div className="mb-2 inline-flex w-fit rounded-full bg-slate-100 px-2 py-1 text-[9px] font-bold uppercase tracking-[0.14em] text-slate-500 sm:mb-3 sm:text-[10px] lg:px-3 lg:text-[11px]">
                  {isTr ? "Uyarlanabilir" : "Adaptable"}
