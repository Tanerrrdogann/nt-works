{
  "name": "nt-works",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack -H 127.0.0.1",
    "dev:turbo": "next dev -H 127.0.0.1",
    "build": "next build --webpack",
    "build:ecommerce-demo": "npm --prefix projects/ecommerce-platform/frontend run build",
    "build:static-demos": "./scripts/build-static-demos.sh",
    "build:prod": "NTWORKS_DEMO_AUTOSTART=0 NTWORKS_STATIC_DEMOS=1 next build --webpack && npm run build:ecommerce-demo && npm run build:static-demos",
    "start": "next start",
    "start:prod": "NTWORKS_DEMO_AUTOSTART=0 NTWORKS_STATIC_DEMOS=1 next start",
    "lint": "eslint",
    "seo:audit": "tsx scripts/seo-audit.ts",
    "seo:audit:strict": "tsx scripts/seo-audit.ts --strict"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
