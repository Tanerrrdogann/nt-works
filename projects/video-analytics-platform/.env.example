POSTGRES_DB=video_analytics
POSTGRES_USER=video_user
POSTGRES_PASSWORD=video_password
DATABASE_URL=postgresql+psycopg://video_user:video_password@postgres:5432/video_analytics

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

API_HOST=0.0.0.0
API_PORT=8000
VITE_API_BASE_URL=
VITE_API_PROXY_TARGET=http://api:8000

STORAGE_ROOT=/app/storage
UPLOAD_STORAGE_DIR=/app/storage/uploads
SNAPSHOT_STORAGE_DIR=/app/storage/snapshots
TEMP_STORAGE_DIR=/app/storage/temp

DEFAULT_SAMPLING_PROFILE=MEDIUM
CLEANUP_TEMP_MAX_AGE_DAYS=7

MOTION_MIN_CONTOUR_AREA=900
YOLO_MODEL_PATH=
YOLO_LABELS_PATH=
YOLO_CONFIDENCE_THRESHOLD=0.45
ENABLE_BUILTIN_OBJECT_DETECTOR=true
HIGH_ACTIVITY_MIN_EVENTS=6
HIGH_ACTIVITY_WINDOW_SECONDS=5
ENABLE_TRANSCRIPTION=true
TRANSCRIPTION_MODEL_SIZE=tiny
TRANSCRIPTION_DEVICE=cpu
TRANSCRIPTION_COMPUTE_TYPE=int8
