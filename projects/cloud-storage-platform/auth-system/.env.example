# Docker Compose reads this file as auth-system/.env.
# Local demo values only. Copy to .env and replace where needed.

VAULT_TOKEN=dev-root-token-change-me

AUTH_DB_PASSWORD=123456
STORAGE_DB_PASSWORD=postgres

RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

STORAGE_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

FRONTEND_BASE_URL=http://localhost:8088

# Optional: set real SMTP credentials only in .env, never in Git.
MAIL_USERNAME=demo@example.com
MAIL_PASSWORD=dev-mail-password-change-me
